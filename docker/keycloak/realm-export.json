{
  "realm": "org-mcp",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "clientScopes": [
    {
      "name": "deployment-invoke",
      "description": "Grants permission to call mcp-server-deployment-service MCP tools",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "deployment-service-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "",
            "included.custom.audience": "deployment-service",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "llm-mcp-client",
      "name": "Org AI Assistant (MCP client)",
      "description": "Service account used by llm-mcp-client to call MCP servers via client-credentials",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "llm-mcp-client-secret",
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "deployment-invoke"
      ]
    }
  ]
}
