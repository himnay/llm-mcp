# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- LLM provider ---
OPENAI_API_KEY=

# --- MCP client auth ---
# Static bearer token for STATELESS backend servers (hr/ticket/notification/travel)
MCP_AUTH_TOKEN=
# Keycloak client secret for the org-mcp realm.
# Local docker-compose default is "llm-mcp-client-secret" (must match docker/keycloak/realm-export.json).
MCP_OAUTH2_CLIENT_SECRET=llm-mcp-client-secret

# --- GitHub MCP server ---
GITHUB_TOKEN=

# --- Gmail MCP server ---
GMAIL_ACCESS_TOKEN=

# --- Travel MCP server (Amadeus) ---
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
